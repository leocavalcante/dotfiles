{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#282828",
    "bgHighlight": "#3c3836",
    "bgVisual": "#504945",
    "border": "#665c54",
    "fg": "#ebdbb2",
    "fgMuted": "#a89984",
    "fgSubtle": "#928374",
    "black": "#282828",
    "brightBlack": "#928374",
    "white": "#a89984",
    "brightWhite": "#ebdbb2",
    "red": "#fb4934",
    "brightRed": "#cc241d",
    "orange": "#fe8019",
    "yellow": "#fabd2f",
    "brightYellow": "#d79921",
    "green": "#b8bb26",
    "brightGreen": "#98971a",
    "cyan": "#8ec07c",
    "brightCyan": "#689d6a",
    "blue": "#83a598",
    "brightBlue": "#458588",
    "purple": "#d3869b",
    "magenta": "#b16286",
    "diffAddBg": "#3d4220",
    "diffDeleteBg": "#3e2a1f"
  },
  "theme": {
    "primary": {
      "dark": "blue",
      "light": "blue"
    },
    "secondary": {
      "dark": "purple",
      "light": "purple"
    },
    "accent": {
      "dark": "cyan",
      "light": "cyan"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "yellow",
      "light": "yellow"
    },
    "success": {
      "dark": "green",
      "light": "green"
    },
    "info": {
      "dark": "blue",
      "light": "blue"
    },
    "text": {
      "dark": "fg",
      "light": "bg"
    },
    "textMuted": {
      "dark": "fgMuted",
      "light": "fgSubtle"
    },
    "background": {
      "dark": "bg",
      "light": "brightWhite"
    },
    "backgroundPanel": {
      "dark": "bgHighlight",
      "light": "white"
    },
    "backgroundElement": {
      "dark": "bgHighlight",
      "light": "white"
    },
    "border": {
      "dark": "border",
      "light": "fgSubtle"
    },
    "borderActive": {
      "dark": "fgSubtle",
      "light": "border"
    },
    "borderSubtle": {
      "dark": "border",
      "light": "fgSubtle"
    },
    "diffAdded": {
      "dark": "green",
      "light": "green"
    },
    "diffRemoved": {
      "dark": "red",
      "light": "red"
    },
    "diffContext": {
      "dark": "fgSubtle",
      "light": "fgSubtle"
    },
    "diffHunkHeader": {
      "dark": "fgSubtle",
      "light": "fgSubtle"
    },
    "diffHighlightAdded": {
      "dark": "brightGreen",
      "light": "brightGreen"
    },
    "diffHighlightRemoved": {
      "dark": "brightRed",
      "light": "brightRed"
    },
    "diffAddedBg": {
      "dark": "diffAddBg",
      "light": "#dde5b6"
    },
    "diffRemovedBg": {
      "dark": "diffDeleteBg",
      "light": "#e8c8c0"
    },
    "diffContextBg": {
      "dark": "bgHighlight",
      "light": "white"
    },
    "diffLineNumber": {
      "dark": "fgSubtle",
      "light": "fgMuted"
    },
    "diffAddedLineNumberBg": {
      "dark": "diffAddBg",
      "light": "#dde5b6"
    },
    "diffRemovedLineNumberBg": {
      "dark": "diffDeleteBg",
      "light": "#e8c8c0"
    },
    "markdownText": {
      "dark": "fg",
      "light": "bg"
    },
    "markdownHeading": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownLink": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownLinkText": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownCode": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownBlockQuote": {
      "dark": "fgSubtle",
      "light": "fgSubtle"
    },
    "markdownEmph": {
      "dark": "orange",
      "light": "orange"
    },
    "markdownStrong": {
      "dark": "yellow",
      "light": "yellow"
    },
    "markdownHorizontalRule": {
      "dark": "border",
      "light": "border"
    },
    "markdownListItem": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownListEnumeration": {
      "dark": "orange",
      "light": "orange"
    },
    "markdownImage": {
      "dark": "purple",
      "light": "purple"
    },
    "markdownImageText": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownCodeBlock": {
      "dark": "fg",
      "light": "bg"
    },
    "syntaxComment": {
      "dark": "fgSubtle",
      "light": "fgSubtle"
    },
    "syntaxKeyword": {
      "dark": "red",
      "light": "red"
    },
    "syntaxFunction": {
      "dark": "green",
      "light": "green"
    },
    "syntaxVariable": {
      "dark": "fg",
      "light": "bg"
    },
    "syntaxString": {
      "dark": "green",
      "light": "green"
    },
    "syntaxNumber": {
      "dark": "purple",
      "light": "purple"
    },
    "syntaxType": {
      "dark": "yellow",
      "light": "yellow"
    },
    "syntaxOperator": {
      "dark": "fg",
      "light": "bg"
    },
    "syntaxPunctuation": {
      "dark": "fg",
      "light": "bg"
    }
  }
}
