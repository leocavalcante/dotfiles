{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#fdf6e3",
    "bgHighlight": "#eee8d5",
    "bgVisual": "#eee8d5",
    "border": "#eee8d5",
    "fg": "#657b83",
    "fgMuted": "#93a1a1",
    "fgSubtle": "#93a1a1",
    "black": "#073642",
    "brightBlack": "#002b36",
    "white": "#eee8d5",
    "brightWhite": "#fdf6e3",
    "red": "#dc322f",
    "brightRed": "#cb4b16",
    "orange": "#cb4b16",
    "yellow": "#b58900",
    "brightYellow": "#657b83",
    "green": "#859900",
    "brightGreen": "#586e75",
    "cyan": "#2aa198",
    "brightCyan": "#93a1a1",
    "blue": "#268bd2",
    "brightBlue": "#839496",
