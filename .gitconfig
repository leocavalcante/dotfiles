[core]
    pager = delta
	excludesfile = ~/.gitignore_global

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    # Solarized Dark theme
    syntax-theme = Solarized (dark)
    minus-style = "syntax #073642"
    minus-emph-style = "syntax #3d2028"
    plus-style = "syntax #073642"
    plus-emph-style = "syntax #1a4a2a"
    line-numbers-minus-style = "#dc322f"
    line-numbers-plus-style = "#859900"
    line-numbers-zero-style = "#586e75"
    line-numbers-left-style = "#073642"
    line-numbers-right-style = "#073642"
    hunk-header-style = "syntax #073642"
    hunk-header-decoration-style = "box #073642"
    file-style = "#268bd2 bold"
    file-decoration-style = "none"
    commit-style = "#b58900"
    commit-decoration-style = "none"

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[push]
    autoSetupRemote = true

[pull]
    rebase = false

[include]
    path = ~/.gitconfig.local

[pack]
	threads = 0

[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[alias]
	diff-all = !git diff | delta && git ls-files --others --exclude-standard | xargs -I{} git diff --no-index /dev/null {} | delta

