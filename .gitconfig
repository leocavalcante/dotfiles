[core]
    pager = delta
	excludesfile = ~/.gitignore_global

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    # Gruvbox Dark theme
    syntax-theme = gruvbox-dark
    minus-style = "syntax #3c1f1f"
    minus-emph-style = "syntax #6c2e2e"
    plus-style = "syntax #2e3b1f"
    plus-emph-style = "syntax #4e6b2f"
    line-numbers-minus-style = "#fb4934"
    line-numbers-plus-style = "#b8bb26"
    line-numbers-zero-style = "#928374"
    line-numbers-left-style = "#504945"
    line-numbers-right-style = "#504945"
    hunk-header-style = "syntax #3c3836"
    hunk-header-decoration-style = "box #504945"
    file-style = "#83a598 bold"
    file-decoration-style = "none"
    commit-style = "#fabd2f"
    commit-decoration-style = "none"

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[push]
    autoSetupRemote = true

[pull]
    rebase = false

[include]
    path = ~/.gitconfig.local

[pack]
	threads = 0

[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[alias]
	diff-all = !git diff | delta && git ls-files --others --exclude-standard | xargs -I{} git diff --no-index /dev/null {} | delta

